<ui:FluentWindow x:Class="ArtaleProBuff.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:local="clr-namespace:ArtaleProBuff"
        mc:Ignorable="d"
        Title="Artale 智能Buff助手 (Pro版)" 
        Height="750" 
        Width="780"
        WindowStartupLocation="CenterScreen"
        WindowBackdropType="Mica"
        ExtendsContentIntoTitleBar="True">

    <Window.Resources>
        <local:HexToBrushConverter x:Key="HexToBrushConverter" />
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Custom title bar for Mica integration -->
        <ui:TitleBar Grid.Row="0" x:Name="AppTitleBar" Title="Artale 智能Buff助手 (Pro版)">
            <ui:TitleBar.Icon>
                <ui:SymbolIcon Symbol="Shield24" />
            </ui:TitleBar.Icon>
        </ui:TitleBar>

        <!-- Main navigation layout -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <ui:NavigationView Grid.Column="0" x:Name="RootNavigation" PaneDisplayMode="Left" IsBackButtonVisible="Collapsed">
                <ui:NavigationView.MenuItems>
                    <ui:NavigationViewItem Content="常规按键" TargetPageType="{x:Null}" Icon="{ui:SymbolIcon Keyboard24}" Click="NavigationViewItem_Click" />
                    <ui:NavigationViewItem Content="多组巡逻" TargetPageType="{x:Null}" Icon="{ui:SymbolIcon Navigation24}" Click="NavigationViewItem_Click" />
                    <ui:NavigationViewItem Content="配置预设" TargetPageType="{x:Null}" Icon="{ui:SymbolIcon Database24}" Click="NavigationViewItem_Click" />
                    <ui:NavigationViewItem Content="全局与安全" TargetPageType="{x:Null}" Icon="{ui:SymbolIcon Settings24}" Click="NavigationViewItem_Click" />
                </ui:NavigationView.MenuItems>
            </ui:NavigationView>

            <Grid Grid.Column="1" Margin="12">
                <!-- Tab 1: Regular Keys -->
                <ScrollViewer x:Name="KeysPanel" Visibility="Visible" VerticalScrollBarVisibility="Auto">
                        <StackPanel local:StackPanelHelper.Spacing="10">
                            <!-- Global configuration Card -->
                            <ui:Card Padding="12">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <!-- Delay Setting -->
                                    <StackPanel Grid.Row="0" Grid.Column="0" Margin="4">
                                        <TextBlock Text="启动延时 (秒):" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,4"/>
                                        <ui:TextBox x:Name="txtGlobalDelay" Text="0" Width="100" HorizontalAlignment="Left" />
                                    </StackPanel>

                                    <!-- Background Mode -->
                                    <StackPanel Grid.Row="0" Grid.Column="1" VerticalAlignment="Center" Margin="4">
                                        <ui:ToggleSwitch x:Name="switchBgMode" Content="启用后台挂机" Checked="SwitchBgMode_Changed" Unchecked="SwitchBgMode_Changed" />
                                    </StackPanel>

                                    <!-- Target Window Combobox -->
                                    <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Margin="4,8,4,4" x:Name="panelBgWindow" Visibility="Collapsed">
                                        <TextBlock Text="目标窗口标题:" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,4"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <ComboBox Grid.Column="0" x:Name="comboBgWindow" IsEditable="True" Text="MapleStory Worlds" DropDownOpened="ComboBgWindow_DropDownOpened" />
                                            <ui:Button Grid.Column="1" Content="刷新" Margin="6,0,0,0" Click="BtnRefreshWindows_Click" />
                                        </Grid>
                                    </StackPanel>

                                    <!-- Save Config Button -->
                                    <ui:Button Grid.Row="0" Grid.Column="2" Grid.RowSpan="2" Content="保存配置" Icon="{ui:SymbolIcon Save24}" Click="BtnSaveConfig_Click" VerticalAlignment="Center" Margin="10,0,0,0" Appearance="Secondary" />
                                </Grid>
                            </ui:Card>

                            <!-- Dynamic macro list -->
                            <ItemsControl x:Name="listBuffCards">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <ui:Card Margin="0,0,0,8" Padding="12">
                                            <StackPanel local:StackPanelHelper.Spacing="6">
                                                <!-- Card Header -->
                                                <Grid>
                                                    <CheckBox IsChecked="{Binding IsActive, Mode=TwoWay}" VerticalAlignment="Center">
                                                        <TextBlock Text="启用此按键" FontWeight="SemiBold" FontSize="13"/>
                                                    </CheckBox>
                                                    <ui:Button Content="×" FontSize="14" FontWeight="Bold" Padding="4,2,4,2" HorizontalAlignment="Right" Appearance="Transparent" Click="BtnDeleteCard_Click" Foreground="{DynamicResource SystemFillColorCriticalBrush}"/>
                                                </Grid>
                                                
                                                <Border Height="1" Background="{DynamicResource DividerStrokeColorDefaultBrush}" Margin="0,2,0,4"/>

                                                <!-- Entry Fields -->
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Grid.Column="0" Margin="2">
                                                        <TextBlock Text="按键" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,4"/>
                                                        <ui:TextBox Text="{Binding Key, Mode=TwoWay}" HorizontalContentAlignment="Center"/>
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="1" Margin="2">
                                                        <TextBlock Text="间隔 (秒)" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,4"/>
                                                        <ui:TextBox Text="{Binding IntervalText, Mode=TwoWay}" HorizontalContentAlignment="Center"/>
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="2" Margin="2">
                                                        <TextBlock Text="波动 (%)" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,4"/>
                                                        <ui:TextBox Text="{Binding FluctuationText, Mode=TwoWay}" HorizontalContentAlignment="Center"/>
                                                    </StackPanel>
                                                </Grid>

                                                <!-- Long Press & Exclusive Options -->
                                                <Grid Margin="0,4,0,0">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <CheckBox Grid.Column="0" IsChecked="{Binding IsLongPress, Mode=TwoWay}" VerticalAlignment="Center">
                                                        <TextBlock Text="长按模式" Style="{StaticResource CaptionTextBlockStyle}"/>
                                                    </CheckBox>
                                                    <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="10,0,0,0" IsEnabled="{Binding IsLongPress}">
                                                        <TextBlock Text="时长:" VerticalAlignment="Center" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,4,0"/>
                                                        <ui:TextBox Text="{Binding HoldTimeText, Mode=TwoWay}" Width="60" HorizontalContentAlignment="Center" VerticalAlignment="Center" />
                                                    </StackPanel>
                                                    <CheckBox Grid.Column="2" IsChecked="{Binding IsExclusive, Mode=TwoWay}" HorizontalAlignment="Right" VerticalAlignment="Center">
                                                        <TextBlock Text="独占执行" Style="{StaticResource CaptionTextBlockStyle}"/>
                                                    </CheckBox>
                                                </Grid>

                                                <Border Height="1" Background="{DynamicResource DividerStrokeColorDefaultBrush}" Margin="0,4,0,2"/>

                                                <!-- Status & Progress reporting -->
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0" Text="{Binding Status}" Style="{StaticResource CaptionTextBlockStyle}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                                    <TextBlock Grid.Column="1" Text="{Binding VariationText}" Style="{StaticResource CaptionTextBlockStyle}" VerticalAlignment="Center" Foreground="{Binding VariationColor, Converter={StaticResource HexToBrushConverter}}"/>
                                                </Grid>
                                                <ProgressBar Maximum="{Binding ProgressMax}" Value="{Binding ProgressValue}" Height="4" Margin="0,2,0,0" Foreground="{DynamicResource SystemAccentColorBrush}"/>
                                            </StackPanel>
                                        </ui:Card>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <!-- Add Button -->
                            <ui:Button Content="+ 添加新按键配置" Icon="{ui:SymbolIcon Add24}" Click="BtnAddCard_Click" HorizontalAlignment="Stretch" Margin="0,4,0,10" Height="40" FontSize="14" Appearance="Primary" />
                        </StackPanel>
                    </ScrollViewer>

                    <!-- Tab 2: Patrol Settings -->
                    <ScrollViewer x:Name="PatrolPanel" Visibility="Collapsed" VerticalScrollBarVisibility="Auto">
                        <StackPanel local:StackPanelHelper.Spacing="10">
                            <!-- Toggle switch for Patrol -->
                            <ui:Card Padding="12">
                                <ui:ToggleSwitch x:Name="switchPatrolMode" Content="启用多组左右巡逻位移功能" Checked="SwitchPatrolMode_Changed" Unchecked="SwitchPatrolMode_Changed" />
                            </ui:Card>

                            <!-- Patrol global options -->
                            <ui:Card Padding="12">
                                <StackPanel local:StackPanelHelper.Spacing="8">
                                    <CheckBox x:Name="chkPatrolPauseOthers" IsChecked="True">
                                        <TextBlock Text="巡逻移动时暂停其他技能按键触发" Style="{StaticResource CaptionTextBlockStyle}"/>
                                    </CheckBox>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="间隔随机波动 (%):" VerticalAlignment="Center" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                        <ui:TextBox Grid.Column="1" x:Name="txtPatrolFluct" Text="10" Width="80" HorizontalContentAlignment="Center" Margin="10,0,0,0"/>
                                    </Grid>
                                </StackPanel>
                            </ui:Card>

                            <!-- List of patrol groups -->
                            <ItemsControl x:Name="listPatrolGroups">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <ui:Card Margin="0,0,0,8" Padding="12">
                                            <StackPanel local:StackPanelHelper.Spacing="6">
                                                <!-- Header -->
                                                <Grid>
                                                    <CheckBox IsChecked="{Binding IsActive, Mode=TwoWay}" VerticalAlignment="Center">
                                                        <TextBlock Text="启用此巡逻组" FontWeight="SemiBold" FontSize="13"/>
                                                    </CheckBox>
                                                    <ui:Button Content="×" FontSize="14" FontWeight="Bold" Padding="4,2,4,2" HorizontalAlignment="Right" Appearance="Transparent" Click="BtnDeletePatrolGroup_Click" Foreground="{DynamicResource SystemFillColorCriticalBrush}"/>
                                                </Grid>

                                                <Border Height="1" Background="{DynamicResource DividerStrokeColorDefaultBrush}" Margin="0,2,0,4"/>

                                                <!-- Durations -->
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Grid.Column="0" Margin="2">
                                                        <TextBlock Text="向右时长 (秒)" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,4"/>
                                                        <ui:TextBox Text="{Binding RightTimeText, Mode=TwoWay}" HorizontalContentAlignment="Center"/>
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="1" Margin="2">
                                                        <TextBlock Text="中途停留 (秒)" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,4"/>
                                                        <ui:TextBox Text="{Binding MidPauseTimeText, Mode=TwoWay}" HorizontalContentAlignment="Center"/>
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="2" Margin="2">
                                                        <TextBlock Text="向左时长 (秒)" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,4"/>
                                                        <ui:TextBox Text="{Binding LeftTimeText, Mode=TwoWay}" HorizontalContentAlignment="Center"/>
                                                    </StackPanel>
                                                </Grid>

                                                <!-- Interval and Status -->
                                                <Grid Margin="0,4,0,0">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0" Text="组后间隔时间 (秒):" VerticalAlignment="Center" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                                    <ui:TextBox Grid.Column="1" Text="{Binding IntervalAfterText, Mode=TwoWay}" Width="80" HorizontalContentAlignment="Center" HorizontalAlignment="Left" Margin="10,0,0,0"/>
                                                    <TextBlock Grid.Column="2" Text="{Binding Status}" Style="{StaticResource CaptionTextBlockStyle}" VerticalAlignment="Center" FontWeight="SemiBold" Foreground="{DynamicResource SystemAccentColorBrush}"/>
                                                </Grid>

                                                <!-- Timed Loop Settings -->
                                                <Grid Margin="0,4,0,0">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <CheckBox Grid.Column="0" Content="定时循环" IsChecked="{Binding IsTimedLoop, Mode=TwoWay}" VerticalAlignment="Center" Margin="0,0,10,0" FontSize="11" />
                                                    <TextBlock Grid.Column="1" Text="每隔 (秒):" VerticalAlignment="Center" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" IsEnabled="{Binding IsTimedLoop}"/>
                                                    <ui:TextBox Grid.Column="2" Text="{Binding LoopIntervalText, Mode=TwoWay}" Width="55" HorizontalContentAlignment="Center" Margin="5,0,15,0" IsEnabled="{Binding IsTimedLoop}"/>
                                                    <TextBlock Grid.Column="3" Text="单次执行次数:" VerticalAlignment="Center" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" IsEnabled="{Binding IsTimedLoop}"/>
                                                    <ui:TextBox Grid.Column="4" Text="{Binding LoopCountText, Mode=TwoWay}" Width="45" HorizontalContentAlignment="Center" HorizontalAlignment="Left" Margin="5,0,0,0" IsEnabled="{Binding IsTimedLoop}"/>
                                                </Grid>
                                            </StackPanel>
                                        </ui:Card>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <!-- Add Patrol Group -->
                            <ui:Button Content="+ 添加巡逻组" Icon="{ui:SymbolIcon Add24}" Click="BtnAddPatrolGroup_Click" HorizontalAlignment="Stretch" Margin="0,4,0,10" Height="40" FontSize="14" Appearance="Primary" />

                            <!-- Patrol status monitoring -->
                            <ui:Card Padding="12" x:Name="cardPatrolStatus">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <ui:SymbolIcon Symbol="Directions24" FontSize="20" Foreground="{DynamicResource SystemAccentColorBrush}" VerticalAlignment="Center" Margin="0,0,10,0" />
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="当前巡逻状态监控" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                        <TextBlock x:Name="txtPatrolStatus" Text="等待运行..." FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource TextFillColorPrimaryBrush}" Margin="0,4,0,0"/>
                                    </StackPanel>
                                </Grid>
                            </ui:Card>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- Tab 3: Presets Page -->
                    <ScrollViewer x:Name="PresetsPanel" Visibility="Collapsed" VerticalScrollBarVisibility="Auto">
                        <StackPanel local:StackPanelHelper.Spacing="10">
                            <!-- Add/Overwrite preset -->
                            <ui:CardExpander Header="💾 新增 / 覆盖预设方案" Icon="{ui:SymbolIcon DocumentSave24}" IsExpanded="True">
                                <StackPanel local:StackPanelHelper.Spacing="8" Margin="0,6,0,0">
                                    <TextBlock Text="预设名称:" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <ui:TextBox Grid.Column="0" x:Name="txtPresetName" Text="预设方案1" />
                                        <ui:Button Grid.Column="1" Content="保存当前配置" Icon="{ui:SymbolIcon SaveCopy24}" Click="BtnSavePreset_Click" Margin="10,0,0,0" Appearance="Primary"/>
                                    </Grid>
                                </StackPanel>
                            </ui:CardExpander>

                            <!-- Manage presets -->
                            <ui:CardExpander Header="📂 管理及加载已存预设" Icon="{ui:SymbolIcon FolderOpen24}" IsExpanded="True">
                                <StackPanel local:StackPanelHelper.Spacing="10" Margin="0,6,0,0">
                                    <TextBlock Text="选择已有预设:" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                    <ComboBox x:Name="comboPresets" SelectedIndex="0" />
                                    
                                    <ui:Button Content="📂 应用选中预设" Click="BtnLoadPreset_Click" HorizontalAlignment="Stretch" Appearance="Primary" Height="36" />
                                    
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <ui:Button Grid.Column="0" Content="📤 导出选定预设" Click="BtnExportPreset_Click" Icon="{ui:SymbolIcon ArrowExportLtr24}" HorizontalAlignment="Stretch" Margin="0,0,5,0" />
                                        <ui:Button Grid.Column="1" Content="📥 导入外部预设" Click="BtnImportPreset_Click" Icon="{ui:SymbolIcon ArrowImport24}" HorizontalAlignment="Stretch" Margin="5,0,0,0" />
                                    </Grid>
                                    
                                    <ui:Button Content="❌ 删除选中预设" Click="BtnDeletePreset_Click" Icon="{ui:SymbolIcon Delete24}" HorizontalAlignment="Stretch" Appearance="Danger" Height="36"/>
                                </StackPanel>
                            </ui:CardExpander>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- Tab 4: Global & Safety Settings -->
                    <ScrollViewer x:Name="SettingsPanel" Visibility="Collapsed" VerticalScrollBarVisibility="Auto">
                        <StackPanel local:StackPanelHelper.Spacing="10">
                            <!-- Theme selector -->
                             <ui:Card Padding="12">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="外观配色" FontSize="14" FontWeight="SemiBold"/>
                                        <TextBlock Text="切换深色与浅色 Windows 11 Fluent 视觉主题" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,2,0,0"/>
                                    </StackPanel>
                                    <ui:Button Grid.Column="1" x:Name="btnThemeToggle" Content="🌙 深色模式" Click="BtnThemeToggle_Click" Width="120" />
                                </Grid>
                              </ui:Card>

                            <!-- EXP monitor settings -->
                            <ui:CardExpander Header="📈 经验值监测机制 (防符文静止检测)" Icon="{ui:SymbolIcon HeartPulse24}" IsExpanded="True">
                                <StackPanel local:StackPanelHelper.Spacing="10" Margin="0,6,0,0">
                                    <ui:ToggleSwitch x:Name="switchExpMonitor" Content="启用经验值监测功能" Checked="SwitchExpMonitor_Changed" Unchecked="SwitchExpMonitor_Changed" />

                                    <StackPanel x:Name="panelExpFields" local:StackPanelHelper.Spacing="10">
                                        <ui:ToggleSwitch x:Name="switchExpCloseGame" Content="超时强制物理关闭游戏窗口 (防封号强退)" />

                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="超时判定时间阈值 (秒):" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,4"/>
                                                <ui:TextBox x:Name="txtExpTimeout" Text="15" Width="100" HorizontalAlignment="Left" />
                                            </StackPanel>
                                            <ui:Button Grid.Column="1" Content="选择经验值监控区域" Icon="{ui:SymbolIcon Crop24}" Click="BtnSelectExpRegion_Click" VerticalAlignment="Bottom" Appearance="Primary" />
                                        </Grid>

                                        <!-- Real-time monitoring area -->
                                        <Border BorderBrush="{DynamicResource DividerStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="4" Background="{DynamicResource CardBackgroundFillColorDefaultBrush}" Padding="10">
                                            <StackPanel local:StackPanelHelper.Spacing="8">
                                                <!-- 1. Live screen -->
                                                <TextBlock Text="实时监控画面 (所选区域):" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                                <Border BorderBrush="{DynamicResource SystemAccentColorBrush}" BorderThickness="1" HorizontalAlignment="Left" Background="Black" CornerRadius="2" Padding="2">
                                                    <Image x:Name="imgExpRegion" Width="220" Height="40" Stretch="Uniform" />
                                                </Border>

                                                <!-- 2. OCR text -->
                                                <TextBlock Text="识别到的经验值文本:" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                                <TextBlock x:Name="txtExpOcrText" Text="未识别到数据" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>

                                                <!-- 3. Growth rate -->
                                                <TextBlock Text="经验增长速度分析:" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Grid.Column="0">
                                                        <TextBlock Text="每分钟增长:" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                                        <TextBlock x:Name="txtExpRateMin" Text="0.00%" FontSize="15" FontWeight="Bold" Foreground="{DynamicResource SystemAccentColorBrush}"/>
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="1">
                                                        <TextBlock Text="每 10 分钟增长:" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                                        <TextBlock x:Name="txtExpRate10Min" Text="0.00%" FontSize="15" FontWeight="Bold" Foreground="{DynamicResource SystemAccentColorBrush}"/>
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="2">
                                                        <TextBlock Text="累计增长:" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                                        <TextBlock x:Name="txtExpTotalGained" Text="0.00%" FontSize="15" FontWeight="Bold" Foreground="{DynamicResource SystemAccentColorBrush}"/>
                                                    </StackPanel>
                                                </Grid>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>

                                    <!-- Status -->
                                    <ui:Card Padding="10" Background="{DynamicResource CardBackgroundFillColorDefaultBrush}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <ui:SymbolIcon Symbol="Pulse24" FontSize="18" Foreground="{DynamicResource SystemAccentColorBrush}" VerticalAlignment="Center" Margin="0,0,10,0" />
                                            <StackPanel Grid.Column="1">
                                                <TextBlock Text="监测状态报告:" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                                <TextBlock x:Name="txtExpStatus" Text="监测关闭" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource TextFillColorPrimaryBrush}" Margin="0,2,0,0"/>
                                            </StackPanel>
                                        </Grid>
                                    </ui:Card>
                                 </StackPanel>
                            </ui:CardExpander>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Grid>

        <!-- Bottom controls (F9 Start, F10 Stop) & Watermark -->
        <Border Grid.Row="2" Background="{DynamicResource SolidBackgroundFillColorBaseBrush}" VerticalAlignment="Bottom" Padding="12,10,12,10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <ui:Button Grid.Column="0" x:Name="btnStart" Content="全部启动 (F9)" Click="BtnStart_Click" Icon="{ui:SymbolIcon Play24}" Height="46" FontSize="15" FontWeight="Bold" Appearance="Success" HorizontalAlignment="Stretch" Margin="0,0,6,0"/>
                    <ui:Button Grid.Column="1" x:Name="btnStop" Content="停止运行 (F10)" Click="BtnStop_Click" Icon="{ui:SymbolIcon Stop24}" Height="46" FontSize="15" FontWeight="Bold" Appearance="Danger" HorizontalAlignment="Stretch" Margin="6,0,0,0" IsEnabled="False" />
                </Grid>
